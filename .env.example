DATA_DIR=Data
VECTORSTORE_DIR=vectorstore
VECTOR_BACKEND=faiss
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=electrical_rag_chunks
UPLOAD_DIR=Data/uploads
MAX_UPLOAD_SIZE_MB=25
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
PRELOAD_RAG_SERVICE=true
WARMUP_EMBEDDING_MODEL=true
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
RAG_MIN_RETRIEVAL_SCORE=0.30
ENABLE_RERANKER=false
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
MAX_CHUNKS_PER_SOURCE_PAGE=2
MAX_CONTEXT_CHARS=3500
MAX_CHUNK_CHARS=900
ENABLE_OCR_FALLBACK=true
OCR_LANGUAGES=en,fr
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Optional override used by Docker Compose service:
LMSTUDIO_BASE_URL_DOCKER=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MODEL=local-model
LMSTUDIO_HEALTH_TIMEOUT_SECONDS=3
LLM_TEMPERATURE=0.1
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
APP_RELEASE=local
ENABLE_METRICS=true
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=development
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_CAPTURE_CONTENT=false
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://electrical_rag:electrical_rag@localhost:5432/electrical_rag
REDIS_URL=redis://localhost:6379/0
ENABLE_CHAT_CACHE=true
CHAT_CACHE_TTL_SECONDS=3600
ENABLE_RATE_LIMIT=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
